{
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "node": true,
    "es2020": true
  },
  "rules": {
    // "@typescript-eslint/no-explicit-any": "warn",
    // "@typescript-eslint/no-unused-vars": "warn"
    "@typescript-eslint/no-explicit-any": "off", // отключить предупреждения об any
    "@typescript-eslint/no-unused-vars": "off", // отключить предупреждения о неиспользуемых переменных
    "@typescript-eslint/no-unused-expressions": "off" // отключить предупреждения о выражениях
  }
}